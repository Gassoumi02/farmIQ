<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.farmiq.controllers.CalendarController"
           style="-fx-background-color: #F5F5F5;">
    
    <HBox spacing="20" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
          style="-fx-padding: 20;">
        
        <!-- Calendar Grid -->
        <VBox HBox.hgrow="ALWAYS">
            <!-- Header -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="btnPrevMonth" text="←" onAction="#onPreviousMonth"
                        style="-fx-background-color: #E0E0E0; -fx-background-radius: 4;"/>
                <Label fx:id="lblMonthYear" text="Février 2026" 
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
                <Button fx:id="btnNextMonth" text="→" onAction="#onNextMonth"
                        style="-fx-background-color: #E0E0E0; -fx-background-radius: 4;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToday" text="Aujourd'hui" onAction="#onToday"
                        style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-background-radius: 4;"/>
                <Button fx:id="btnAddTask" text="+ Nouvelle tâche" onAction="#onAddTask"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 4;"/>
            </HBox>
            
            <!-- Calendar Grid -->
            <GridPane fx:id="gridCalendar" hgap="2" vgap="2" 
                      style="-fx-padding: 10; -fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"
                      VBox.vgrow="ALWAYS" maxHeight="400">
                <!-- Day headers and cells will be created programmatically -->
            </GridPane>
        </VBox>
        
        <!-- Tasks Panel -->
        <VBox minWidth="300" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label fx:id="lblSelectedDate" text="Mardi 24 Février 2026" 
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
            
            <Separator style="-fx-padding: 10 0;"/>
            
            <Label text="Tâches du jour:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" maxHeight="400">
                <VBox fx:id="vboxTasks" spacing="8">
                    <!-- Tasks will be added programmatically -->
                </VBox>
            </ScrollPane>
        </VBox>
        
    </HBox>
</AnchorPane>
