<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.farmiq.controllers.RegisterController"
            stylesheets="@../css/admin.css"
            styleClass="login-root"
            prefWidth="900" prefHeight="700">
    <center>
        <HBox alignment="CENTER" styleClass="login-wrapper">

            <!-- LEFT PANEL -->
            <VBox styleClass="login-brand-panel" alignment="CENTER" spacing="24" prefWidth="400">
                <Label text="🌾" style="-fx-font-size: 64px;"/>
                <Label text="FarmIQ" styleClass="login-brand-title"/>
                <Label text="Créez votre compte Agriculteur" styleClass="login-brand-sub" wrapText="true" textAlignment="CENTER"/>
            </VBox>

            <!-- RIGHT PANEL - Form -->
            <VBox styleClass="login-form-panel" alignment="CENTER" spacing="0" prefWidth="420">
                <VBox styleClass="login-form-inner" spacing="14">
                    <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

                    <Label text="Inscription" styleClass="login-title"/>
                    <Label text="Créez votre compte FarmIQ" styleClass="login-subtitle"/>

                    <!-- Nom -->
                    <VBox spacing="4">
                        <Label text="Nom complet *" styleClass="form-label"/>
                        <TextField fx:id="fieldNom" promptText="Votre nom" styleClass="form-input login-input"/>
                        <Label fx:id="errNom" styleClass="error-label" visible="false" managed="false"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="4">
                        <Label text="Email *" styleClass="form-label"/>
                        <TextField fx:id="fieldEmail" promptText="votre@email.com" styleClass="form-input login-input"/>
                        <Label fx:id="errEmail" styleClass="error-label" visible="false" managed="false"/>
                    </VBox>

                    <!-- Password with eye toggle -->
                    <VBox spacing="4">
                        <Label text="Mot de passe *" styleClass="form-label"/>
                        <StackPane styleClass="password-stack">
                            <PasswordField fx:id="fieldPassword"
                                           promptText="Min 8 car, majuscule, chiffre, spécial"
                                           styleClass="form-input login-input password-field-pad"/>
                            <TextField fx:id="fieldPasswordVisible"
                                       promptText="Min 8 car, majuscule, chiffre, spécial"
                                       styleClass="form-input login-input password-field-pad"
                                       visible="false" managed="false"/>
                            <Button fx:id="btnTogglePassword"
                                    text="👁"
                                    styleClass="btn-eye"
                                    onAction="#handleTogglePassword"
                                    StackPane.alignment="CENTER_RIGHT"/>
                        </StackPane>
                        <Label fx:id="errPassword" styleClass="error-label" visible="false" managed="false"/>
                    </VBox>

                    <!-- Confirm Password with eye toggle -->
                    <VBox spacing="4">
                        <Label text="Confirmer mot de passe *" styleClass="form-label"/>
                        <StackPane styleClass="password-stack">
                            <PasswordField fx:id="fieldConfirm"
                                           promptText="Répéter le mot de passe"
                                           styleClass="form-input login-input password-field-pad"/>
                            <TextField fx:id="fieldConfirmVisible"
                                       promptText="Répéter le mot de passe"
                                       styleClass="form-input login-input password-field-pad"
                                       visible="false" managed="false"/>
                            <Button fx:id="btnToggleConfirm"
                                    text="👁"
                                    styleClass="btn-eye"
                                    onAction="#handleToggleConfirm"
                                    StackPane.alignment="CENTER_RIGHT"/>
                        </StackPane>
                        <Label fx:id="errConfirm" styleClass="error-label" visible="false" managed="false"/>
                    </VBox>

                    <Label fx:id="statusLabel" text="" styleClass="status-info" wrapText="true"/>

                    <Button fx:id="btnRegister" text="Créer mon compte" styleClass="btn-login"
                            maxWidth="Infinity" onAction="#handleRegister" defaultButton="true"/>

                    <HBox alignment="CENTER" spacing="8">
                        <Label text="Déjà un compte ?" styleClass="link-text"/>
                        <Button text="Se connecter" styleClass="btn-link" onAction="#handleGoToLogin"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
